    # Frontend (Next.js)
    handle /* {
        reverse_proxy frontend:3000
    }

    # Backend (Rust axum) — API routes
    handle /api/agent/* {
        reverse_proxy backend:8080
    }
    handle /api/auth/backend/* {
        reverse_proxy backend:8080
    }
    handle /health {
        reverse_proxy backend:8080
    }

    encode gzip
    log {
        output stdout
    }
}
